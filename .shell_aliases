# Sourced by ~/.bashrc and ~/.zshrc — POSIX alias syntax only.

# Git — shortcuts
alias g-s='git status'
alias g-a='git add'
alias g-ap='git add -p'
alias g-p='git push'
# Log — g-l / g-lo / g-lg … (pass extra args: g-lo -5, g-lg main..HEAD)
alias g-l='git log'
alias g-lo='git log --oneline'
alias g-lg='git log --oneline --graph --decorate'
alias g-la='git log --oneline --graph --decorate --all'
alias g-lst='git log --stat'
alias g-lr='git log --oneline -20'
alias g-l1='git log -1'
alias g-l1p='git log -1 -p'
# Commit with message (staged only): g-c <msg>  (~/dotfiles/bin)
# Add all + commit: g-a-c <msg>  (~/dotfiles/bin)
# Add all + commit + push: g-a-c-p <msg>  or  g-c-p <msg>  (~/dotfiles/bin; same)
# Backdated commits: g-1-ago … g-48-ago  (~/dotfiles/bin; GNU date)

# Sessions
alias t-ls='tmux list-sessions'
alias t-a='tmux attach -t'
alias t-at='tmux attach'
alias t-ad='tmux attach -d -t'
alias t-n='tmux new'
alias t-ns='tmux new-session -s'
alias t-k='tmux kill-session -t'
alias t-kall='tmux kill-server'

# Client / config
alias t-d='tmux detach-client'
alias t-src='tmux source-file ~/.tmux.conf'
