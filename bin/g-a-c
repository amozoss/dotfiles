#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") <commit message>" >&2
  echo "git add -A, then git commit -m \"…\" (no push)." >&2
}

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: not inside a git repository." >&2
  exit 1
fi

msg="$*"

git add -A
git commit -m "$msg"
