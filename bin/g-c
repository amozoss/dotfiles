#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") <commit message>" >&2
  echo "Commits staged changes: git commit -m \"…\"." >&2
}

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: not inside a git repository." >&2
  exit 1
fi

msg="$*"
git commit -m "$msg"
