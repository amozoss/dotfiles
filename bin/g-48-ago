#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") <commit message>" >&2
  echo "Creates a new git commit dated 48 hours ago (stages with: git add -A)." >&2
}

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: not inside a git repository." >&2
  exit 1
fi

msg="$*"
when="$(date -d '48 hours ago' -Is)"

git add -A
GIT_AUTHOR_DATE="$when" GIT_COMMITTER_DATE="$when" git commit -m "$msg"
